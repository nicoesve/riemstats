Package: riemstats
Title: Riemannian ANOVA Statistics for SPD Matrices
Version: 0.1.0
Authors@R: c(
    person(
        given = "Nicolas",
        family = "Escobar",
        role = c("aut", "cre"),
        email = "nescoba@iu.edu",
